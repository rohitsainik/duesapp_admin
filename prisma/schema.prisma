// ================= Generator & Datasource =================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================== Enums ===========================
enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum LoanStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum InterestMethod {
  SIMPLE
  MONTHLY_FLAT
  COMPOUND
  REDUCING
}

enum CollateralStatus {
  PLEDGED
  RELEASED
  SEIZED
}

enum CollateralType {
  PROPERTY
  GOLD
  VEHICLE
  CASH_FD
  SECURITIES
  OTHER
}

// ======================== Models ==========================
model User {
  id           String  @id @default(cuid())
  userId       String  @unique
  name         String?
  email        String? @unique
  phone        String?
  location     String?
  role         Role    @default(USER)
  passwordHash String
  refreshToken String? // ← custom JWT refresh token

  adminId String?
  admin   User?   @relation("AdminUsers", fields: [adminId], references: [id])
  users   User[]  @relation("AdminUsers")

  loansBorrowed Loan[] @relation("BorrowerLoans")
  loansManaged  Loan[] @relation("AdminLoans")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([adminId])
}

model Loan {
  id String @id @default(cuid())

  borrowerId String
  borrower   User   @relation("BorrowerLoans", fields: [borrowerId], references: [id])

  adminId String
  admin   User   @relation("AdminLoans", fields: [adminId], references: [id])

  principal Decimal @db.Decimal(18, 2)
  rate      Decimal @db.Decimal(8, 4)
  months    Int
  startDate DateTime
  endDate   DateTime?

  interestMethod InterestMethod @default(SIMPLE)

  lockIn         Boolean @default(false)
  minMonthsFloor Int     @default(0)

  status        LoanStatus @default(ACTIVE)
  totalInterest Decimal?   @db.Decimal(18, 2)
  totalPayable  Decimal?   @db.Decimal(18, 2)

  depositedPrincipal Decimal @default(0) @db.Decimal(18, 2)
  depositedInterest  Decimal @default(0) @db.Decimal(18, 2)

  notes String?

  isSecured   Boolean      @default(false)
  collaterals Collateral[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([borrowerId])
  @@index([adminId])
  @@index([status])
  @@index([startDate])
}

model PaymentReceiptManual {
  id String @id @default(cuid())

  loanId      String
  adminUserId String

  depositedAt DateTime @default(now())
  amount      Decimal  @db.Decimal(18, 2)

  depositPrincipal Decimal? @db.Decimal(18, 2)
  depositInterest  Decimal? @db.Decimal(18, 2)

  note String?

  borrowerUserId String?
  principal      Decimal? @db.Decimal(18, 2)
  rate           Decimal? @db.Decimal(8, 4)
  months         Int?
  interestMethod String?

  createdAt DateTime @default(now())

  @@index([loanId, createdAt])
  @@index([adminUserId])
}

model Collateral {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])

  type           CollateralType
  title          String
  description    String?
  estimatedValue Decimal          @db.Decimal(18, 2)
  status         CollateralStatus @default(PLEDGED)
  appraisalAt    DateTime?
  notes          String?

  documentUrls String[] @db.VarChar(512)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([loanId])
  @@index([type, status])
}